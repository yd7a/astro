---
---

<div class="mb-8 space-x-0">
  <p class="text-xs opacity-80">

  </p>
</div>

<form id="contact-form" novalidate class="flex flex-col gap-4">
  <input type="hidden" name="access_key" value="dcb55179-e58c-468b-b267-b68c1cd0ae50" />
  <input type="hidden" name="subject" value="【統一教会2世清算連絡会】ウェブサイトからのご連絡" />
  <input type="hidden" name="from_name" value="統一教会2世清算連絡会フォーム" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

  <div class="rounded-lg bg-slate-100 p-4 dark:bg-slate-900">
    <div class="flex items-center  border-border focus-within:border-accent">
      <span class="flex-shrink-0 text-sm font-semibold">ニックネーム</span>
      <input
        type="text"
        id="name"
        name="name"
        class="flex-1 bg-transparent px-3 py-2 text-sm outline-none"
        placeholder="本名の使用はお控えください"
      />
    </div>
  </div>

  <div class="rounded-lg bg-slate-100 p-4 dark:bg-slate-900">
    <div class="flex items-center border-border focus-within:border-accent">
      <span class="flex-shrink-0 text-sm font-semibold">メール<span class="text-red-500">*</span></span>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="flex-1 bg-transparent px-3 py-2 text-sm outline-none"
        placeholder="your@email.com"
      />
    </div>
  </div>

  <div class="rounded-lg bg-slate-100 p-4 dark:bg-slate-900">
    <div class="flex flex-col border-border focus-within:border-accent">
      <span class="flex-shrink-0 text-sm font-semibold mb-2">メッセージ<span class="text-red-500">*</span></span>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        class="w-full bg-transparent text-sm outline-none resize-y"
        placeholder="個人情報をできるかぎり伏せた上で、自由にご記入ください"
      ></textarea>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <button
      type="submit"
      class="rounded bg-slate-300 px-5 py-4 text-sm font-medium text-slate-900 hover:bg-slate-400 disabled:opacity-50 dark:bg-slate-700 dark:text-slate-100 dark:hover:bg-slate-600"
    >
      送信
    </button>
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <input
          type="checkbox"
          id="privacy"
          name="privacy"
          required
          class="rounded border border-border"
        />
        <label for="privacy" class="text-sm"><a href="../about#2" target="_blank">プライバシーポリシー</a>に同意する<span class="text-red-500">*</span></label>
      </div>
      <div class="flex items-center gap-2">
        <input
          type="checkbox"
          id="newsletter"
          name="newsletter"
          class="rounded border border-border"
        />
        <label for="newsletter" class="text-sm">ニュースレターを購読する</label>
      </div>
    </div>
  </div>
  <p id="contact-result" class="text-sm hidden"></p>
</form>

<script>
  if (!window.contactFormInitialized) {
    window.contactFormInitialized = true;

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const result = document.getElementById("contact-result") as HTMLParagraphElement;
    const submitButton = form?.querySelector("button[type=submit]") as HTMLButtonElement;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = (form.querySelector("#email") as HTMLInputElement)?.value.trim();
      const message = (form.querySelector("#message") as HTMLTextAreaElement)?.value.trim();
      const privacy = (form.querySelector("#privacy") as HTMLInputElement)?.checked;

      result.classList.remove("hidden", "text-accent", "text-red-500");

      if (!email || !message) {
        result.classList.add("text-red-500");
        result.textContent = "*は必須項目です";
        result.classList.remove("hidden");
        return;
      }

      if (!privacy) {
        result.classList.add("text-red-500");
        result.textContent = "プライバシーポリシーに同意してください。";
        result.classList.remove("hidden");
        return;
      }

      submitButton.disabled = true;

      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });

      const json = await res.json();

      result.classList.remove("hidden");
      if (json.success) {
        result.innerHTML = '送信完了。contact@seisan.insaem.jp からのお返事をお待ちください';
        result.classList.add("text-accent");
        form.reset();
      } else {
        result.textContent = json.message ?? "エラーが発生しました。contact@seisan.insaem.jp までご連絡ください";
        result.classList.add("text-red-500");
        submitButton.disabled = false;
      }
    });
  }
</script>
