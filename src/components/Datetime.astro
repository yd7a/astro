---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: Date | string | null | undefined;
  modDatetime?: Date | string | null;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
} = Astro.props;

if (!pubDatetime) return;

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = dayjs(isModified ? modDatetime : pubDatetime).tz(SITE.timezone);
const date = datetime.format("YYYY.MM.DD");
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class:list={["inline-block size-4 min-w-4", { "scale-90": size === "sm" }]}
    width="24" height="24" viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round"
  >
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
    <line x1="16" y1="2" x2="16" y2="6"></line>
    <line x1="8" y1="2" x2="8" y2="6"></line>
    <line x1="3" y1="10" x2="21" y2="10"></line>
  </svg>

  <time
    class:list={["font-mono text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}
  >{date}</time>
</div>
